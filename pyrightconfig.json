{
    "venvPath": ".",
    "venv": "venv",
    "exclude": [
        "**/node_modules",
        "**/__pycache__",
        "venv"
    ],
    "reportMissingImports": true,
    "reportMissingTypeStubs": false,
    "pythonVersion": "3.12",
    "pythonPlatform": "Windows",
    "executionEnvironments": [
        {
            "root": "backend",
            "extraPaths": [
                "backend"
            ]
        }
    ]
}
